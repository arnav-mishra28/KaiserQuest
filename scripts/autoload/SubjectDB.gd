# ══════════════════════════════════════════════════════════════════════════════
#  QUESTIONS — Full bank per branch
# ══════════════════════════════════════════════════════════════════════════════
func get_questions(subject: String, branch: String) -> Array:
	var key := subject + ":" + branch
	return _questions.get(key, _questions.get(subject+":generic", []))

func get_gym_questions(subject: String, branch: String, gym_num: int, count: int) -> Array:
	var all_q := get_questions(subject, branch)
	if all_q.is_empty(): return []
	var min_d = max(1, (gym_num - 1) / 5)
	var filtered: Array = all_q.filter(func(q): return int(q.get("difficulty",1)) >= min_d)
	if filtered.size() < count: filtered = all_q.duplicate()
	return AdaptiveAI.adaptive_select(filtered, subject+":"+branch, GameManager.get_level(), count)

