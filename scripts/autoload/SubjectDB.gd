#  GYM LEADERS — 20 PER BRANCH (we define 3 sample branches fully)
# ══════════════════════════════════════════════════════════════════════════════
func get_gym_leader(subject: String, branch: String, gym_num: int) -> Dictionary:
	var key := subject + ":" + branch
	var leaders = _leaders.get(key, {})
	if leaders.is_empty():
		return _generic_leader(subject, branch, gym_num)
	return leaders.get(gym_num, _generic_leader(subject, branch, gym_num))

func _generic_leader(subject: String, branch: String, gym_num: int) -> Dictionary:
	var act := 1 if gym_num <= 5 else (2 if gym_num <= 12 else 3)
	var diff_name = ["Easy","Easy","Medium","Medium","Hard","Hard","Hard","Expert","Expert","Expert","Expert","Expert","Master","Master","Master","Master","Grandmaster","Grandmaster","Grandmaster","Legend"][gym_num-1]
	var col_map := {"math":Color("#2060d0"),"languages":Color("#c07010"),"music":Color("#8020c0")}
	var col = col_map.get(subject, Color("#606060"))
	var b_data: Dictionary = SUBJECTS.get(subject,{}).get("branches",{}).get(branch,{})
	return {
		"name":       "Gym Leader " + str(gym_num),
		"title":      "Guardian of " + b_data.get("name","Knowledge") + " Gym " + str(gym_num),
		"badge_name": b_data.get("name","") + " Badge " + str(gym_num),
		"gym_number": gym_num, "act": act,
		"xp_reward":  200 + gym_num * 50,
		"color":      col,
		"world":      subject + ":" + branch,
		"intro": ["Gym "+str(gym_num)+" — "+diff_name+" difficulty!",
				  "I am the Guardian of "+b_data.get("name","")+" Gym "+str(gym_num)+".",
				  str(5+min(gym_num,5))+" questions. "+str(min(gym_num/5+2,4))+" lives.\n\nBegin!"],
		"win":  ["★ "+b_data.get("name","")+" Badge "+str(gym_num)+" earned! ★",
				 "You grow stronger."],
		"lose": ["Defeated... Study more!", "Return when ready."],
	}

