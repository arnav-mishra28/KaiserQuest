; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="KaiserQuest"
config/description="Learn · Level Up · Become Kaiser"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
AlgebraDB="*res://scripts/data/AlgebraQuestions.gd"
EnglishDB="*res://scripts/data/EnglishQuestions.gd"
MusicDB="*res://scripts/data/MusicQuestions.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=320
window/size/window_width_override=960
window/size/window_height_override=640
window/stretch/mode="canvas_items"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
